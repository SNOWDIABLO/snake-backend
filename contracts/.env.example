# SnakeBoostNFT — deploy env vars
# Copie vers .env et remplis les valeurs.
# NE JAMAIS commit le .env (voir .gitignore).

# RPC Polygon mainnet
POLYGON_RPC=https://polygon-rpc.com

# Testnet (optionnel, pour dry-run)
AMOY_RPC=https://rpc-amoy.polygon.technology

# Wallet deployer — needs 5-10 POL de gas
# Clé rotée après deploy
DEPLOYER_PK=0x_FILL_ME

# Auto-verify sur Polygonscan (gratuit, clé API = 1 min)
POLYGONSCAN_API_KEY=FILL_ME

# Addresses Polygon (DÉJÀ CONNUES — mainnet)
# Chainlink MATIC/USD (fiable, 8 decimals)
CHAINLINK_MATIC_USD=0xAB594600376Ec9fD91F8e885dADF0CE036862dE0

# $SNAKE ERC-20 (déjà déployé)
SNAKE_TOKEN_ADDRESS=0x25e5Af25f5D8d87Df779f5eeA32dc7478663e9a1

# Wallet qui recevra les royalties secondaire (5%) + withdraw POL (primaire)
# = même wallet que payout tournois + clan_fee
FEE_WALLET=0xFca2595d1EE2d2d417f6e404330Ca72934054fc9
