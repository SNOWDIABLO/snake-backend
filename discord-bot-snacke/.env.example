# Discord
DISCORD_TOKEN=         # Bot token (https://discord.com/developers)
DISCORD_CLIENT_ID=     # Application ID
DISCORD_GUILD_ID=      # Your Discord server ID (right click → Copy Server ID)
DISCORD_CHANNEL_ID=    # Channel where on-chain events get posted
DISCORD_HOLDER_ROLE_ID=# Role ID to assign to $SNAKE holders (optional)

# Backend API
BACKEND_URL=https://snake-backend-production-e5e8.up.railway.app

# Polygon
POLYGON_RPC=https://polygon-rpc.com
CONTRACT_ADDRESS=0x25e5Af25f5D8d87Df779f5eeA32dc7478663e9a1

# Holder role threshold (in $SNAKE, human-readable)
HOLDER_THRESHOLD=1000

# Minimum Transfer value to post in channel (in $SNAKE)
MIN_TRANSFER_POST=10

# How often to refresh holder roles (ms, default 10 min)
ROLE_REFRESH_MS=600000
