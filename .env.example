# Clé privée du wallet SIGNER (PAS ton wallet perso - un wallet dédié vide)
# Format: 0x + 64 caractères hex
SIGNER_PK=0xTON_SIGNER_PRIVATE_KEY_ICI

# Adresse du smart contract déployé sur Polygon
CONTRACT_ADDRESS=0xTON_CONTRACT_ADDRESS_ICI

# Limite journalière de tokens par wallet
DAILY_LIMIT=100

# Max tokens par session de jeu
MAX_PER_SESSION=50

# Port (Railway l'assigne automatiquement)
PORT=3000
