# ============================================
#  snake-backend — root gitignore
# ============================================

# Secrets
.env
.env.*
!.env.example

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build / cache
dist/
.vite/
.cache/
coverage/

# Vite dev timestamp configs (generated on every `vite` / `vite build`)
**/vite.config.js.timestamp-*.mjs
**/vite.config.ts.timestamp-*.mjs

# Runtime DB (Railway volume persists this server-side)
snake.db
snake.db-journal
*.sqlite
*.sqlite-journal

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Editors
.vscode/
.idea/
*.swp
*.swo

# Hardhat
contracts/artifacts/
contracts/cache/
contracts/typechain-types/

# Backup files
*.bak
*.orig

# Date-stamped DB dumps (local backups, never commit)
snake-*.db
snake-*.db-journal
snake-*-backup.db
